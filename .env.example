# Copy this file to `.env` before running `docker compose up --build`.

# --- PostgreSQL ---
POSTGRES_USER=shareflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shareflow

# --- API ---
# Required. Generate one with: openssl rand -hex 32
APP_SECRET=

# Public origin of the web app (used to build share links, e.g. https://share.example.com)
PUBLIC_APP_URL=http://localhost:5173
# Public origin of the API (used to build download links; also baked into the web build)
PUBLIC_API_URL=http://localhost:4000
# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:5173

UPLOAD_RATE_LIMIT_PER_HOUR=100
DOWNLOAD_RATE_LIMIT_PER_HOUR=300
CLEANUP_CRON_INTERVAL_MINUTES=15
