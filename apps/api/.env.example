NODE_ENV=development
PORT=4000

# postgresql://<user>:<password>@<host>:5432/<database>?schema=public
DATABASE_URL="postgresql://postgres@localhost:5432/shareflow_dev?schema=public"

# Required. Generate with: openssl rand -hex 32
APP_SECRET="change-me-to-a-random-32-byte-hex-string"

PUBLIC_APP_URL="http://localhost:5173"
PUBLIC_API_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:5173"

STORAGE_ROOT="../../data/storage/objects"
UPLOAD_TEMP_ROOT="../../data/storage/tmp-uploads"

# Storage backend: "local" (default) or "r2". UPLOAD_TEMP_ROOT is still used
# for in-flight chunk assembly even with "r2" — only the final merged object
# goes to R2.
STORAGE_PROVIDER="local"
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

UPLOAD_RATE_LIMIT_PER_HOUR=100
DOWNLOAD_RATE_LIMIT_PER_HOUR=300
CLEANUP_CRON_INTERVAL_MINUTES=15
